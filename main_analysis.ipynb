   "source": [
    "train_df, val_df = train_test_split(df, test_size=0.2, random_state = seed, shuffle=True)\n",
    "\n",
    "#use a smaller subset to make pipeline run faster\n",
    "train_df = train_df.sample(n=4000, random_state=seed).reset_index(drop=True)\n",
    "val_df = val_df.sample(n=2000, random_state=seed).reset_index(drop=True)\n",
    "\n",
    "print(\"Train subset:\", len(train_df))\n",
    "print(\"Val subset:\", len(val_df))"
   ]
  },
