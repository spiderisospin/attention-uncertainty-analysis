   "source": [
    "best_model_name = \"levit_128\"\n",
    "\n",
    "test_transform = levit_val_transform\n",
    "\n",
    "best_model = levit_128s(n_targets)\n",
    "best_model.load_state_dict(torch.load(levit_path, map_location=device))\n",
    "best_model.to(device)\n",
    "best_model.eval();"
   ]
  },
