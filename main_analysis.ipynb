   ]
  },
  {
   "cell_type": "code",
   "execution_count": 16,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "YljoAB_YmOJA",
    "outputId": "42ee0587-421a-4ff9-b667-c29294c3ad72"
   },
   "outputs": [
    {
     "name": "stdout",
